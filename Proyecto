import os
from flask import Flask, render_template, request, redirect, url_for
from psycopg2 import sql
from database import get_connection
import requests

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
app = Flask(__name__, template_folder=os.path.join(BASE_DIR, "templates"))

TABLAS = {"actividades": "actividades", "personales": "actividades_personales"}
USUARIO_GH = "kmgnazate-ship-it"
ENLACE_DESTACADO = "https://github.com/kmgnazate-ship-it/Ejercicios/tree/main/Ejercios%20de%20Orientacion"


def tabla_valida(nombre):
    return TABLAS.get(nombre, TABLAS["actividades"])


def ejecutar(tabla_real, plantilla_sql, params=None, fetch=None):
    """Ejecuta SELECT/INSERT/UPDATE/DELETE de forma segura sobre 'tabla_real'."""
    conexion = get_connection()
    cursor = conexion.cursor()
    consulta = sql.SQL(plantilla_sql).format(tabla=sql.Identifier(tabla_real))
    cursor.execute(consulta, params or ())
    resultado = None
    if fetch == "all":
        resultado = cursor.fetchall()
    elif fetch == "one":
        resultado = cursor.fetchone()
    else:
        conexion.commit()
    cursor.close()
    conexion.close()
    return resultado


@app.route("/")
def index():
    tabla_param = request.args.get("tabla", "actividades")
    tabla_real = tabla_valida(tabla_param)
    editar_id = request.args.get("editar")
    error, registros, registro_editar = None, [], None
    try:
        registros = ejecutar(tabla_real, "SELECT id, mensaje, actividad, estado FROM {tabla} ORDER BY id", fetch="all")
        if editar_id:
            registro_editar = ejecutar(tabla_real, "SELECT id, mensaje, actividad, estado FROM {tabla} WHERE id=%s", (editar_id,), fetch="one")
    except Exception as e:
        error = str(e)
    return render_template("index.html", registros=registros, tabla=tabla_param,
                            registro_editar=registro_editar, error=error)


@app.route("/agregar", methods=["POST"])
def agregar():
    tabla_param = request.form.get("tabla", "actividades")
    try:
        ejecutar(tabla_valida(tabla_param), "INSERT INTO {tabla} (mensaje, actividad, estado) VALUES (%s, %s, %s)",
                 (request.form.get("mensaje", ""), request.form.get("actividad", ""), request.form.get("estado", "Pendiente")))
    except Exception as e:
        print("Error al agregar:", e)
    return redirect(url_for("index", tabla=tabla_param))


@app.route("/actualizar/<int:id>", methods=["POST"])
def actualizar(id):
    tabla_param = request.form.get("tabla", "actividades")
    try:
        ejecutar(tabla_valida(tabla_param), "UPDATE {tabla} SET mensaje=%s, actividad=%s, estado=%s WHERE id=%s",
                 (request.form.get("mensaje", ""), request.form.get("actividad", ""), request.form.get("estado", "Pendiente"), id))
    except Exception as e:
        print("Error al actualizar:", e)
    return redirect(url_for("index", tabla=tabla_param))


@app.route("/eliminar/<int:id>")
def eliminar(id):
    tabla_param = request.args.get("tabla", "actividades")
    try:
        ejecutar(tabla_valida(tabla_param), "DELETE FROM {tabla} WHERE id=%s", (id,))
    except Exception as e:
        print("Error al eliminar:", e)
    return redirect(url_for("index", tabla=tabla_param))


@app.route("/hola")
def hola():
    return "¡Hola! Bienvenido al proyecto de Kevin 👋"


@app.route("/github")
def github():
    tabla_param = request.args.get("tabla", "actividades")
    repos, error, registros = [], None, []
    try:
        r = requests.get(f"https://api.github.com/users/{USUARIO_GH}/repos", timeout=5)
        if r.status_code == 200:
            repos = [{"nombre": x["name"], "url": x["html_url"]} for x in r.json()]
        else:
            error = "No se pudo obtener los repositorios de GitHub"
    except Exception as e:
        error = str(e)
    try:
        registros = ejecutar(tabla_valida(tabla_param), "SELECT id, mensaje, actividad, estado FROM {tabla} ORDER BY id", fetch="all")
    except Exception as e:
        error = error or str(e)
    return render_template("github.html", repos=repos, error=error, registros=registros,
                            tabla=tabla_param, usuario=USUARIO_GH, enlace_destacado=ENLACE_DESTACADO)

if __name__ == "__main__":
    app.run(debug=True)


