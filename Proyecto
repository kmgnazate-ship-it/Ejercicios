<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Proyecto de Kevin</title>
<style>
body{background:#0d0d0d;color:#eee;font-family:Segoe UI,Arial;margin:0}
header{background:linear-gradient(90deg,#b30000,#4d0000);padding:25px;text-align:center;box-shadow:0 3px 10px #000}
header h1{margin:0;font-size:28px;letter-spacing:1px}
header p{margin:5px 0 0;opacity:.8}
nav{text-align:center;margin:18px}
nav a{color:#fff;background:#b30000;padding:9px 18px;margin:4px;text-decoration:none;border-radius:20px;font-size:14px;display:inline-block;transition:.2s}
nav a:hover{background:#ff1a1a}
nav a.activo{background:#fff;color:#b30000;font-weight:bold}
.contenedor{width:92%;max-width:900px;margin:0 auto}
table{width:100%;border-collapse:collapse;margin:20px 0;box-shadow:0 0 10px #000}
th{background:#b30000;padding:10px}
td{border:1px solid #330000;padding:10px;text-align:center;background:#1a1a1a}
tr:hover td{background:#241010}
td a{color:#ff8080;margin:0 4px;text-decoration:none;font-weight:bold}
.card{background:#1a1a1a;border:1px solid #b30000;border-radius:10px;padding:18px;margin-bottom:25px}
.card input,.card select{width:95%;padding:9px;margin:6px 0;border-radius:6px;border:1px solid #b30000;background:#0d0d0d;color:#fff}
.estado{padding:4px 10px;border-radius:12px;font-size:12px;font-weight:bold;display:inline-block}
.estado-pendiente{background:#5c1a1a;color:#ffb3b3}
.estado-progreso{background:#5c4b1a;color:#ffe0a3}
.estado-completado{background:#1a5c2a;color:#b3ffc2}
.card button{background:#b30000;color:#fff;border:none;padding:9px 20px;border-radius:6px;cursor:pointer;font-weight:bold}
.card button:hover{background:#ff1a1a}
h2{color:#ff6666;text-align:center}
.error{width:92%;max-width:900px;margin:15px auto;background:#3a0000;border:1px solid red;padding:12px;color:#ffb3b3;border-radius:6px}
</style>
</head>
<body>

<header>
<h1>Proyecto de Kevin</h1>
<p>Sistema de Actividades con Flask y PostgreSQL</p>
</header>

<nav>
<a class="{{ 'activo' if tabla=='actividades' else '' }}" href="/?tabla=actividades">Tabla Actividades</a>
<a class="{{ 'activo' if tabla=='personales' else '' }}" href="/?tabla=personales">Tabla Personales</a>
<a href="/github">GitHub</a>
</nav>

{% if error %}<div class="error"><strong>Error:</strong> {{ error }}</div>{% endif %}

<div class="contenedor">
<table>
<tr><th>ID</th><th>Mensaje</th><th>Actividad</th><th>Estado</th><th>Acciones</th></tr>
{% for r in registros %}
<tr>
<td>{{ r[0] }}</td><td>{{ r[1] }}</td><td>{{ r[2] }}</td>
<td><span class="estado {{ 'estado-completado' if r[3]=='Completado' else ('estado-progreso' if r[3]=='En progreso' else 'estado-pendiente') }}">{{ r[3] }}</span></td>
<td><a href="/?tabla={{ tabla }}&editar={{ r[0] }}">Editar</a>
<a href="/eliminar/{{ r[0] }}?tabla={{ tabla }}" onclick="return confirm('¿Eliminar?');">Eliminar</a></td>
</tr>
{% endfor %}
</table>

<h2>{{ 'Editar registro' if registro_editar else 'Agregar nuevo registro' }}</h2>

{% if registro_editar %}
<form class="card" action="/actualizar/{{ registro_editar[0] }}" method="POST">
<input type="hidden" name="tabla" value="{{ tabla }}">
<input type="text" name="mensaje" value="{{ registro_editar[1] }}" required>
<input type="text" name="actividad" value="{{ registro_editar[2] }}" required>
<select name="estado">
<option value="Pendiente" {{ 'selected' if registro_editar[3]=='Pendiente' else '' }}>Pendiente</option>
<option value="En progreso" {{ 'selected' if registro_editar[3]=='En progreso' else '' }}>En progreso</option>
<option value="Completado" {{ 'selected' if registro_editar[3]=='Completado' else '' }}>Completado</option>
</select>
<button type="submit">Actualizar</button>
<a href="/?tabla={{ tabla }}" style="color:#ff8080">Cancelar</a>
</form>
{% else %}
<form class="card" action="/agregar" method="POST">
<input type="hidden" name="tabla" value="{{ tabla }}">
<input type="text" name="mensaje" placeholder="Mensaje (ej: Viernes - Beca)" required>
<input type="text" name="actividad" placeholder="Actividad" required>
<select name="estado">
<option value="Pendiente">Pendiente</option>
<option value="En progreso">En progreso</option>
<option value="Completado">Completado</option>
</select>
<button type="submit">Agregar</button>
</form>
{% endif %}
</div>

</body>
</html>

